<Window x:Class="RouteOptimizer.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RouteOptimizer - Вход" Height="260" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" MinHeight="310" MinWidth="420">
    <Border Margin="14" Background="White" CornerRadius="10" BorderBrush="#DDD" BorderThickness="1" Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="RouteOptimizer" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,16"/>
            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBlock Text="Логин"/>
                <TextBox x:Name="LoginBox"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Margin="0,0,0,8">
                <TextBlock Text="Пароль"/>
                <PasswordBox x:Name="PasswordBox"/>
            </StackPanel>
            <TextBlock x:Name="ErrorText" Grid.Row="3" Foreground="DarkRed" Margin="4,0,4,6"/>
            <Button Grid.Row="4" Content="Войти" HorizontalAlignment="Right" Width="120" Height="34" Click="Login_Click"/>
        </Grid>
    </Border>
</Window>
