<Window x:Class="RouteOptimizer.RouteEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Маршрут" Height="360" Width="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Margin="12" Background="White" CornerRadius="10" BorderBrush="#DDD" BorderThickness="1" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Номер маршрута"/>
                <TextBox x:Name="RouteNumberBox"/>
            </StackPanel>

            <StackPanel Grid.Row="1">
                <TextBlock Text="Тип транспорта"/>
                <ComboBox x:Name="TransportTypeBox" DisplayMemberPath="TypeName" SelectedValuePath="TransportTypeId"/>
            </StackPanel>

            <StackPanel Grid.Row="2">
                <TextBlock Text="Оператор"/>
                <ComboBox x:Name="OperatorBox" DisplayMemberPath="OperatorName" SelectedValuePath="OperatorId"/>
            </StackPanel>

            <StackPanel Grid.Row="3">
                <TextBlock Text="Интервал, мин"/>
                <TextBox x:Name="IntervalBox"/>
            </StackPanel>

            <Grid Grid.Row="4" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,6,0">
                    <TextBlock Text="Начало (HH:mm)"/>
                    <TextBox x:Name="StartTimeBox"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Конец (HH:mm)"/>
                    <TextBox x:Name="EndTimeBox"/>
                </StackPanel>
            </Grid>

            <CheckBox x:Name="ActiveBox" Grid.Row="5" Content="Активен" Margin="4,10,0,0"/>

            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="Сохранить" Width="110" Click="Save_Click"/>
                <Button Content="Отмена" Width="90" Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
