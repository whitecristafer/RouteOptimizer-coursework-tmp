<Window x:Class="RouteOptimizer.StopPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор остановки" Height="420" Width="360" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Margin="12" Background="White" CornerRadius="10" BorderBrush="#DDD" BorderThickness="1" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Остановки" FontSize="16" FontWeight="SemiBold" Margin="4"/>
            <ListBox x:Name="StopsList" Grid.Row="1" DisplayMemberPath="StopName"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Выбрать" Width="100" Click="Select_Click"/>
                <Button Content="Отмена" Width="90" Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
